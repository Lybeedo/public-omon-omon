//+------------------------------------------------------------------+
//|                                          nexus-core.nexus-mq4    |
//|                                    VicChelenge System v1.0       |
//|                                       Cuancux Algo Traders       |
//|                                                                 |
//|  OUT-OF-THE-BOX STRATEGY:                                       |
//|  1. Smart Money Structure (Order Blocks, FVGs, Liquidity)       |
//|  2. Market Regime Detection (via nexus-regime API)              |
//|  3. Delta Absorption (volume imbalance detection)                |
//|  4. Adaptive Position Sizing (regime confidence-weighted)        |
//|  5. Multi-Timeframe Confirmation (H4/H1/M15/M5)                |
//|                                                                 |
//|  NO MARTINGALE. NO GRID. NO GAMBLE.                             |
//|  PURE INSTITUTIONAL FLOW + AI INSIGHTS.                        |
//+------------------------------------------------------------------+
#property copyright "VicChelenge System - Cuancux Algo Traders"
#property link      "https://github.com/cuancux/VicChelenge-System"
#property version   "1.0"
#property strict

//+------------------------------------------------------------------+
//| INPUTS - API CONFIG                                              |
//+------------------------------------------------------------------+
input group "=== NEXUS API CONNECTION ==="
input string   InpAPIHost      = "http://localhost:8000"; // Nexus API Host
input string   InpAPIKey      = "nexus-secret-key-2026"; // API Auth Key
input int      InpAPITimeout  = 5000;                   // API timeout (ms)
input bool     InpUseAPI      = true;                   // Enable API regime detection
input int      InpAPIRetry    = 3;                     // Max API retry on failure

//+------------------------------------------------------------------+
//| INPUTS - SMART MONEY STRUCTURE                                    |
//+------------------------------------------------------------------+
input group "=== SMART MONEY STRUCTURE ==="
input bool     InpUseSMS      = true;                   // Enable Smart Money Structure
input int      InpOBLookback  = 10;                    // Order Block lookback bars
input int      InpFVGLookback = 3;                     // Fair Value Gap lookback bars
input double   InpFVGMit      = 0.5;                   // FVG mitigation % (0.5 = 50%)
input int      InpLiquiLookback=5;                     // Liquidity grab lookback bars
input double   InpBreakerLookback=3.0;                 // Breaker block confirmation bars

//+------------------------------------------------------------------+
//| INPUTS - MARKET REGIME (Manual Fallback)                          |
//+------------------------------------------------------------------+
input group "=== MARKET REGIME (Fallback if API off) ==="
input ENUM_REGIME InpRegime   = REGIME_TRENDING;       // Current regime
input double      InpRegimeConf=0.7;                   // Regime confidence (0-1)

enum ENUM_REGIME {
   REGIME_TRENDING_STRONG=0,  // ADX>25, EMA aligned
   REGIME_TRENDING_WEAK=1,    // ADX 15-25
   REGIME_RANGING=2,          // ADX<15, MA sandwich
   REGIME_VOLATILE=3,         // ATR > 2x MA
   REGIME_LOW_VOLUME=4,       // Volume < 50% avg
   REGIME_BREAKOUT=5,         // Pump/dump pattern
   REGIME_UNKNOWN=6
};

//+------------------------------------------------------------------+
//| INPUTS - MULTI-TIMEFRAME                                         |
//+------------------------------------------------------------------+
input group "=== MULTI-TIMEFRAME ==="
input ENUM_TIMEFRAMES InpHTF   = PERIOD_H4;            // Higher TF (trend)
input ENUM_TIMEFRAMES InpMTF   = PERIOD_H1;            // Medium TF (zone)
input ENUM_TIMEFRAMES InpLTF   = PERIOD_M15;           // Lower TF (entry)

//+------------------------------------------------------------------+
//| INPUTS - DELTA ABSORPTION                                         |
//+------------------------------------------------------------------+
input group "=== DELTA ABSORPTION ==="
input bool     InpUseDelta    = true;                   // Enable delta detection
input int      InpDeltaPeriod= 20;                     // Delta SMA period
input double   InpDeltaThreshold=0.3;                  // Absorption threshold

//+------------------------------------------------------------------+
//| INPUTS - RISK MANAGEMENT                                         |
//+------------------------------------------------------------------+
input group "=== RISK MANAGEMENT ==="
input double   InpRiskPercent = 1.0;                   // Max risk per trade (%)
input double   InpMaxRiskPerDay=3.0;                  // Max risk per day (%)
input int      InpMaxTradesPerDay=5;                  // Max trades per day
input double   InpMaxDDPercent = 15.0;                // Max drawdown % (pause)
input int      InpMaxOpenTrades=3;                   // Max concurrent trades
input int      InpSlippage    = 3;                    // Slippage points
input bool     InpUseBreakeven=false;                // Move SL to BE after 1R
input double   InpTrailingStart=2.0;                  // Trail start (R units)
input double   InpTrailingStep =0.5;                  // Trail step (R units)

//+------------------------------------------------------------------+
//| INPUTS - TRADING                                                 |
//+------------------------------------------------------------------+
input group "=== TRADING ==="
input int      InpMagic       = 2026001;              // Magic number
input int      InpMaxSpread   = 25;                   // Max spread points
input int      InpTradeHourStart=8;                   // Trade window start (server hour)
input int      InpTradeHourEnd=20;                    // Trade window end (server hour)
input bool     InpUseSessionFilter=true;              // Enable session filter

//+------------------------------------------------------------------+
//| INTERNALS                                                        |
//+------------------------------------------------------------------+
datetime g_barTimes[4];
datetime g_lastAPICall   = 0;
datetime g_lastTradeTime= 0;
int      g_tradesToday    = 0;
datetime g_dayStart      = 0;
double   g_riskToday      = 0.0;
double   g_equityPeak     = 0.0;
ENUM_REGIME g_currentRegime = REGIME_UNKNOWN;
double   g_regimeConf     = 0.5;

//+------------------------------------------------------------------+
//| STRUCTS                                                           |
//+------------------------------------------------------------------+

struct SSMSBlock {
   double high;
   double low;
   datetime time;
   bool isBullish;
   double volume;
};

struct SFVG {
   double gapHigh;
   double gapLow;
   datetime time;
   double size;
   double mitigated; // 0-1
};

struct SLiquidityZone {
   double price;
   datetime time;
   string zoneType; // "sweep_high", "sweep_low", "breaker"
   bool confirmed;
};

struct STradeSignal {
   ENUM_ORDER_TYPE tradeType;
   double entry;
   double sl;
   double tp;
   double confidence;
   string rationale;
   string smsType;      // "order_block", "fvg", "liq_sweep", "breaker"
   ENUM_REGIME regime;
   double riskReward;
};

//+------------------------------------------------------------------+
//| CSMSEngine - Smart Money Structure Engine                         |
//+------------------------------------------------------------------+
class CSMSEngine {
private:
   string m_sym;
   SSMSBlock m_orderBlocks[];
   SFVG      m_fvgs[];
   SLiquidityZone m_liquidity[];

public:
   CSMSEngine(string sym) { m_sym = sym; }
   
   //--- DETECT ORDER BLOCKS ---
   // Order Block = candle before a strong move (institutional activity)
   // Bullish OB = bearish candle before bullish impulse
   // Bearish OB = bullish candle before bearish impulse
   void DetectOrderBlocks() {
      ArrayResize(m_orderBlocks, 0);
      int lookback = InpOBLookback;
      
      for(int i = lookback; i >= 2; i--) {
         double c0 = iClose(m_sym, PERIOD_D1, i);
         double o0 = iOpen(m_sym, PERIOD_D1, i);
         double h0 = iHigh(m_sym, PERIOD_D1, i);
         double l0 = iLow(m_sym, PERIOD_D1, i);
         double v0 = iVolume(m_sym, PERIOD_D1, i);
         
         double c1 = iClose(m_sym, PERIOD_D1, i-1);
         double h1 = iHigh(m_sym, PERIOD_D1, i-1);
         double l1 = iLow(m_sym, PERIOD_D1, i-1);
         
         double impulse = MathAbs(c1 - c0);
         double range  = h1 - l1;
         bool isStrongMove = (impulse > range * 0.7); // 70% of range = strong
         bool highVolume   = (v0 > iVolume(m_sym, PERIOD_D1, i+5) * 1.3);
         
         if(!isStrongMove || !highVolume) continue;
         
         int idx = ArraySize(m_orderBlocks);
         ArrayResize(m_orderBlocks, idx + 1);
         
         if(c0 < o0) { // Bearish candle before bullish = Bullish OB
            m_orderBlocks[idx].high     = h0;
            m_orderBlocks[idx].low     = l0;
            m_orderBlocks[idx].isBullish = true;
            m_orderBlocks[idx].volume  = v0;
            m_orderBlocks[idx].time    = iTime(m_sym, PERIOD_D1, i);
         } else if(c0 > o0) { // Bullish candle before bearish = Bearish OB
            m_orderBlocks[idx].high     = h0;
            m_orderBlocks[idx].low     = l0;
            m_orderBlocks[idx].isBullish = false;
            m_orderBlocks[idx].volume  = v0;
            m_orderBlocks[idx].time    = iTime(m_sym, PERIOD_D1, i);
         }
      }
   }
   
   //--- DETECT FAIR VALUE GAPS ---
   // FVG = gap between two candles (inefficiency zone)
   void DetectFVGs() {
      ArrayResize(m_fvgs, 0);
      int lookback = InpFVGLookback;
      
      for(int i = lookback; i >= 1; i--) {
         double c1 = iClose(m_sym, PERIOD_D1, i+1);
         double h1 = iHigh(m_sym, PERIOD_D1, i+1);
         double l1 = iLow(m_sym, PERIOD_D1, i+1);
         double o0 = iOpen(m_sym, PERIOD_D1, i);
         double c0 = iClose(m_sym, PERIOD_D1, i);
         double h0 = iHigh(m_sym, PERIOD_D1, i);
         double l0 = iLow(m_sym, PERIOD_D1, i);
         
         // Bullish FVG: candle i gap below candle i+1
         double bullishGapLow  = h1;
         double bullishGapHigh = l0;
         
         // Bearish FVG: candle i gap above candle i+1
         double bearishGapLow  = h0;
         double bearishGapHigh = l1;
         
         bool hasBullFVG = (bullishGapHigh < bullishGapLow);
         bool hasBearFVG = (bearishGapLow > bearishGapHigh);
         
         if(hasBullFVG) {
            int idx = ArrayResize(m_fvgs, ArraySize(m_fvgs) + 1);
            m_fvgs[idx-1].gapHigh = bullishGapLow;
            m_fvgs[idx-1].gapLow = bullishGapHigh;
            m_fvgs[idx-1].size   = bullishGapLow - bullishGapHigh;
            m_fvgs[idx-1].time   = iTime(m_sym, PERIOD_D1, i);
            m_fvgs[idx-1].mitigated = 0.0;
         }
         
         if(hasBearFVG) {
            int idx = ArrayResize(m_fvgs, ArraySize(m_fvgs) + 1);
            m_fvgs[idx-1].gapHigh = bearishGapLow;
            m_fvgs[idx-1].gapLow = bearishGapHigh;
            m_fvgs[idx-1].size   = bearishGapLow - bearishGapHigh;
            m_fvgs[idx-1].time   = iTime(m_sym, PERIOD_D1, i);
            m_fvgs[idx-1].mitigated = 0.0;
         }
      }
   }
   
   //--- DETECT LIQUIDITY SWEEPS ---
   // Liquidity grab = price hunts above/below key levels (stops)
   void DetectLiquiditySweeps() {
      ArrayResize(m_liquidity, 0);
      int lookback = InpLiquiLookback;
      
      double recentHighs[];
      double recentLows[];
      ArrayResize(recentHighs, lookback);
      ArrayResize(recentLows, lookback);
      
      for(int i = 0; i < lookback; i++) {
         recentHighs[i] = iHigh(m_sym, PERIOD_D1, i);
         recentLows[i] = iLow(m_sym, PERIOD_D1, i);
      }
      
      // Check for sweep of recent highs
      double lastHigh = recentHighs[0];
      double lastLow  = recentLows[0];
      double price = Close(1);
      double wick  = High(1) - Low(1);
      double body  = MathAbs(Close(1) - Open(1));
      
      if(High(1) > lastHigh * 0.9995 && wick > body * 2) {
         // Wick above recent high = liquidity sweep
         int idx = ArrayResize(m_liquidity, ArraySize(m_liquidity) + 1);
         m_liquidity[idx-1].price     = lastHigh;
         m_liquidity[idx-1].time      = Time(1);
         m_liquidity[idx-1].zoneType  = "sweep_high";
         m_liquidity[idx-1].confirmed = true;
      }
      
      if(Low(1) < lastLow * 1.0005 && wick > body * 2) {
         int idx = ArrayResize(m_liquidity, ArraySize(m_liquidity) + 1);
         m_liquidity[idx-1].price     = lastLow;
         m_liquidity[idx-1].time      = Time(1);
         m_liquidity[idx-1].zoneType  = "sweep_low";
         m_liquidity[idx-1].confirmed = true;
      }
   }
   
   //--- CHECK IF PRICE IN ORDER BLOCK ZONE ---
   double GetOBZoneScore(double price, bool isLong) {
      double score = 0;
      for(int i = 0; i < ArraySize(m_orderBlocks); i++) {
         double zoneHigh = m_orderBlocks[i].high;
         double zoneLow  = m_orderBlocks[i].low;
         
         if(price >= zoneLow * 0.9995 && price <= zoneHigh * 1.0005) {
            if((isLong && m_orderBlocks[i].isBullish) ||
               (!isLong && !m_orderBlocks[i].isBullish)) {
               score += m_orderBlocks[i].volume / 1000.0;
            }
         }
      }
      return MathMin(score, 1.0);
   }
   
   //--- CHECK IF PRICE IN FVG ZONE ---
   double GetFVGZoneScore(double price) {
      double score = 0;
      for(int i = 0; i < ArraySize(m_fvgs); i++) {
         if(price >= m_fvgs[i].gapLow && price <= m_fvgs[i].gapHigh) {
            score += 0.3;
         }
      }
      return MathMin(score, 1.0);
   }
   
   //--- GET LIQUIDITY CONTEXT ---
   string GetLiquidityContext() {
      for(int i = 0; i < ArraySize(m_liquidity); i++) {
         double dist = MathAbs(Close(1) - m_liquidity[i].price) / Point;
         if(dist < 100) { // within 100 points
            return m_liquidity[i].zoneType;
         }
      }
      return "none";
   }
   
   int GetOBTotal() { return ArraySize(m_orderBlocks); }
   int GetFVGTotal() { return ArraySize(m_fvgs); }
   int GetLiqTotal() { return ArraySize(m_liquidity); }
};

//+------------------------------------------------------------------+
//| CDeltaEngine - Volume Delta Analysis Engine                      |
//+------------------------------------------------------------------+
class CDeltaEngine {
private:
   string m_sym;
   double m_deltas[];
   double m_deltaSMA;
   
public:
   CDeltaEngine(string sym) { m_sym = sym; }
   
   // Calculate delta from tick volume (proxy for real delta)
   double CalcCurrentDelta() {
      double ticks = iVolume(m_sym, PERIOD_M1, 0);
      double avgTick = 0;
      for(int i = 1; i <= InpDeltaPeriod; i++) {
         avgTick += iVolume(m_sym, PERIOD_M1, i);
      }
      avgTick /= InpDeltaPeriod;
      
      double delta = (ticks - avgTick) / avgTick;
      return delta;
   }
   
   bool IsAbsorption() {
      double delta = CalcCurrentDelta();
      bool highAbsorption = MathAbs(delta) > InpDeltaThreshold;
      bool consolidating = (iHigh(m_sym, PERIOD_M1, 0) - iLow(m_sym, PERIOD_M1, 0)) < 
                           (iHigh(m_sym, PERIOD_M1, 1) - iLow(m_sym, PERIOD_M1, 1));
      return highAbsorption && consolidating;
   }
};

//+------------------------------------------------------------------+
//| CTradeManager - Clean trade operations                           |
//+------------------------------------------------------------------+
class CTradeManager {
public:
   int      m_magic;
   string   m_sym;
   datetime m_lastTrade;
   
   CTradeManager(int magic, string sym) {
      m_magic = magic;
      m_sym   = sym;
      m_lastTrade = 0;
   }
   
   int CountOpenOrders() {
      int cnt = 0;
      for(int i = OrdersTotal() - 1; i >= 0; i--) {
         if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
         if(OrderSymbol() != m_sym) continue;
         if(OrderMagicNumber() != m_magic) continue;
         if(OrderType() > OP_SELL) continue;
         cnt++;
      }
      return cnt;
   }
   
   double CalcLotRisk(double riskPct, double slPoints) {
      double freeMargin = AccountFreeMargin();
      if(freeMargin <= 0 || slPoints <= 0) return 0.01;
      double riskAmt = freeMargin * (riskPct / 100.0);
      double tickVal = MarketInfo(m_sym, MODE_TICKVALUE);
      if(tickVal <= 0) tickVal = 1.0;
      double pipCost = tickVal * slPoints * Point;
      if(pipCost <= 0) pipCost = 1.0;
      double lot = NormalizeDouble(riskAmt / pipCost, 2);
      double minLot = MarketInfo(m_sym, MODE_MINLOT);
      double maxLot = MarketInfo(m_sym, MODE_MAXLOT);
      return MathMax(minLot, MathMin(maxLot, lot));
   }
   
   bool OpenOrder(STradeSignal& sig, string comment) {
      if(CountOpenOrders() >= InpMaxOpenTrades) {
         Print("[nexus] Max open trades reached");
         return false;
      }
      
      RefreshRates();
      
      double price, sl, tp;
      int cmd;
      
      if(sig.tradeType == ORDER_TYPE_BUY) {
         price = Ask;
         sl    = NormalizeDouble(price - sig.sl * Point, Digits);
         tp    = NormalizeDouble(price + sig.tp * Point, Digits);
         cmd   = OP_BUY;
      } else {
         price = Bid;
         sl    = NormalizeDouble(price + sig.sl * Point, Digits);
         tp    = NormalizeDouble(price - sig.tp * Point, Digits);
         cmd   = OP_SELL;
      }
      
      double lot = CalcLotRisk(InpRiskPercent, sig.sl);
      
      // Confidence-weighted lot sizing
      lot = lot * sig.confidence;
      lot = NormalizeDouble(MathMax(MarketInfo(m_sym, MODE_MINLOT), lot), 2);
      
      string fullComment = StringFormat("nexus|%s|%s|%.0f%%", 
         sig.smsType, sig.regime == REGIME_TRENDING_STRONG ? "TREND" : 
         (sig.regime == REGIME_RANGING ? "RANGE" : "MIXED"),
         sig.confidence * 100);
      
      int ticket = OrderSend(m_sym, cmd, lot, price, InpSlippage, sl, tp, fullComment, m_magic, 0,
                             (sig.tradeType == ORDER_TYPE_BUY) ? clrBlue : clrRed);
      
      if(ticket < 0) {
         Print("[OrderSend Error] Err:", GetLastError(), " | Signal:", sig.smsType, 
               " | Conf:", sig.confidence);
         return false;
      }
      
      m_lastTrade = TimeCurrent();
      Print("[NEXUS OPEN] Ticket:", ticket, " | Type:", EnumToString(sig.tradeType),
            " | SMS:", sig.smsType, " | Conf:", sig.confidence, " | RR:", sig.riskReward);
      return true;
   }
   
   void TrailStop(double trailStartR, double trailStepR) {
      for(int i = OrdersTotal() - 1; i >= 0; i--) {
         if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
         if(OrderSymbol() != m_sym) continue;
         if(OrderMagicNumber() != m_magic) continue;
         if(OrderType() > OP_SELL) continue;
         
         double openPrice   = OrderOpenPrice();
         double currentSL   = OrderStopLoss();
         double currentTP   = OrderTakeProfit();
         double orderRR     = (OrderType() == ORDER_TYPE_BUY) ? 
                              ((Bid - openPrice) / Point / (openPrice - currentSL) * Point) :
                              ((openPrice - Ask) / Point / (currentSL - openPrice) * Point);
         
         if(orderRR >= trailStartR) {
            double step     = trailStepR * (orderRR - trailStartR);
            double newSL;
            
            if(OrderType() == ORDER_TYPE_BUY) {
               newSL = currentSL;
               double potentialSL = Bid - step * Point;
               if(potentialSL > currentSL + MarketInfo(m_sym, MODE_POINT)) {
                  newSL = NormalizeDouble(potentialSL, Digits);
               }
            } else {
               newSL = currentSL;
               double potentialSL = Ask + step * Point;
               if(potentialSL < currentSL - MarketInfo(m_sym, MODE_POINT)) {
                  newSL = NormalizeDouble(potentialSL, Digits);
               }
            }
            
            if(MathAbs(newSL - currentSL) > MarketInfo(m_sym, MODE_POINT)) {
               OrderModify(OrderTicket(), openPrice, newSL, currentTP, 0, clrNONE);
            }
         }
      }
   }
};

//+------------------------------------------------------------------+
//| CNexusAPI - HTTP API Communication                                |
//+------------------------------------------------------------------+
class CNexusAPI {
private:
   string m_host;
   string m_key;
   int    m_timeout;
   
public:
   CNexusAPI(string host, string key, int timeout) {
      m_host    = host;
      m_key     = key;
      m_timeout = timeout;
   }
   
   // Get regime from Python backend
   ENUM_REGIME GetRegime(string symbol, double& confidence) {
      if(!InpUseAPI) return InpRegime;
      
      string url = m_host + "/api/v1/regime/classify";
      string headers = "Content-Type: application/json\r\nAuthorization: Bearer " + m_key + "\r\n";
      
      string postData = StringFormat(
         "{\"symbol\":\"%s\",\"tf\":\"%s\",\"adx\":%.4f,\"atr\":%.5f,\"rsi\":%.2f,\"volume_ratio\":%.2f}",
         symbol, "H4",
         iADX(symbol, PERIOD_H4, 14, MAIN, 1),
         iATR(symbol, PERIOD_H4, 14, 1),
         iRSI(symbol, PERIOD_H4, 14, PRICE_CLOSE, 1),
         iVolume(symbol, PERIOD_H4, 0) / iVolume(symbol, PERIOD_H4, 10)
      );
      
      string result = "";
      int res = WebRequest("GET", url, headers, m_timeout, postData, result);
      
      if(res == -1) {
         Print("[NexusAPI] WebRequest failed. Falling back to manual regime.");
         return InpRegime;
      }
      
      // Parse JSON response (simplified)
      // Expected: {"regime": 0, "confidence": 0.85}
      int regimeIdx = (int)InpRegime;
      confidence = 0.7;
      
      int regimePos = StringFind(result, "\"regime\":");
      if(regimePos >= 0) {
         string val = StringSubstr(result, regimePos + 9, 2);
         regimeIdx = (int)StringToDouble(val);
      }
      
      int confPos = StringFind(result, "\"confidence\":");
      if(confPos >= 0) {
         string val = StringSubstr(result, confPos + 13, 4);
         confidence = StringToDouble(val);
      }
      
      return (ENUM_REGIME)regimeIdx;
   }
   
   // Send trade log to backend
   void LogTrade(int ticket, string action, string rationale) {
      if(!InpUseAPI) return;
      
      string url = m_host + "/api/v1/trades/log";
      string headers = "Content-Type: application/json\r\nAuthorization: Bearer " + m_key + "\r\n";
      
      string postData = StringFormat(
         "{\"ticket\":%d,\"action\":\"%s\",\"rationale\":\"%s\",\"time\":\"%s\",\"balance\":%.2f}",
         ticket, action, rationale, TimeToStr(TimeCurrent(), TIME_DATE|TIME_MINUTES), AccountBalance()
      );
      
      string result = "";
      WebRequest("POST", url, headers, m_timeout, postData, result);
   }
   
   // Get LLM analysis for current market
   string GetLLMInsight(string symbol) {
      if(!InpUseAPI) return "";
      
      string url = m_host + "/api/v1/llm/insight";
      string headers = "Content-Type: application/json\r\nAuthorization: Bearer " + m_key + "\r\n";
      
      string postData = StringFormat(
         "{\"symbol\":\"%s\",\"regime\":%d,\"price\":%.5f,\"trend\":\"%s\"}",
         symbol, (int)g_currentRegime,
         Close(1),
         g_currentRegime == REGIME_TRENDING_STRONG ? "bullish" :
         (g_currentRegime == REGIME_RANGING ? "ranging" : "neutral")
      );
      
      string result = "";
      int res = WebRequest("POST", url, headers, m_timeout, postData, result);
      
      if(res >= 0 && result != "") return result;
      return "";
   }
};

//+------------------------------------------------------------------+
//| CAUSAL-EFFECT MARKET DYNAMICS (CEMD) ENGINE                       |
//| Framework: "Cause = Base + Momentum, Effect = Respect/Break"       |
//|           Energy Transfer, Consumption, Return Behavior             |
//|           Target Efficiency, Clean Room, MTF Confluence            |
//+------------------------------------------------------------------+

// Cause regime classification — extends beyond market regime
enum ENUM_CAUSE_REGIME {
   CAUSE_STRONG_TREND,    // displacement besar, return lambat
   CAUSE_WEAK_TREND,      // displacement kecil, return cepat
   CAUSE_RANGE_BOUND,     // cause dekat SR, balancing
   CAUSE_CONSUMPTION,     // cause sering di-test, melemah
   CAUSE_BREAKOUT_BUILD,  // compression menuju area
   CAUSE_ENERGY_TRANSFER, // jauh dari cause, energi habis
   CAUSE_EFFICIENCY_HIGH, // pergerakan searah, clean room
   CAUSE_EFFICIENCY_LOW,  // bolak-balik, obstacle banyak
   CAUSE_UNKNOWN
};

// Base candle types — penyebab (cause) dari pergerakan harga
enum ENUM_BASE_TYPE {
   BASE_DOJI,          // doji candle
   BASE_PINBAR,        // pinbar rejection
   BASE_SHADOW,        // shadow panjang
   BASE_SMALL_BODY,    // small candle (consolidation)
   BASE_HIDDEN_SHADOW, // hidden shadow (wick kecil)
   BASE_MOMENTUM,      // momentum candle (displacement)
   BASE_UNKNOWN
};

struct SCausalZone {
   double    zoneHigh;       // Upper boundary cause zone
   double    zoneLow;        // Lower boundary cause zone
   double    baseOpen;       // Open candle base
   double    baseClose;      // Close candle base
   double    momentumSize;   // Displacement size (pts)
   double    energyLevel;    // 0.0-1.0 (fresh=1.0, consumed=0.0)
   int       consumptionCount; // Berapa kali di-test
   int       baseType;       // ENUM_BASE_TYPE
   datetime  createdTime;    // Waktu cause terbentuk
   datetime  lastTested;     // Waktu terakhir di-test
   bool      isBullish;      // True if bullish cause
   bool      isActive;       // True if still valid
   string    timeframe;      // "H4", "H1", "M15", "M5"
   double    zoneScore;      // Quality score (base + momentum)
};

struct SReturnBehavior {
   datetime  startTime;
   double    startPrice;
   double    currentPrice;
   double    velocity;       // pts per minute
   double    distance;       // distance from cause zone
   bool      isReturning;    // True if price returning to cause
   int       ticksCount;     // Number of ticks during return
   double    pathDeviation;  // Deviation from straight line
};

struct STargetEfficiency {
   double    targetHigh;     // Nearest obstacle (high)
   double    targetLow;      // Nearest obstacle (low)
   double    cleanRoomBuy;   // Distance to target high
   double    cleanRoomSell;  // Distance to target low
   double    compressionRatio; // Target narrowing ratio
   double    obstacleCount;  // Number of obstacles in path
   bool      isEfficient;    // True if clean room > threshold
};

//+------------------------------------------------------------------+
//| CCausalZoneDetector — Detect Cause Zones (Base + Momentum)         |
//+------------------------------------------------------------------+
class CCausalZoneDetector {
private:
   string    m_sym;
   SCausalZone m_zones[];
   ENUM_TIMEFRAMES m_tf;
   int       m_maxZones;
   int       m_lookback;
   
   // Detect base candle type
   ENUM_BASE_TYPE DetectBaseType(int bar) {
      double o = iOpen(m_sym, m_tf, bar);
      double c = iClose(m_sym, m_tf, bar);
      double h = iHigh(m_sym, m_tf, bar);
      double l = iLow(m_sym, m_tf, bar);
      double body = MathAbs(c - o);
      double range = h - l;
      double upperWick = h - MathMax(o, c);
      double lowerWick = MathMin(o, c) - l;
      
      // Doji: body < 10% of range
      if(body < range * 0.1) return BASE_DOJI;
      // Pinbar: wick > 2x body
      if(upperWick > body * 2.0 || lowerWick > body * 2.0) return BASE_PINBAR;
      // Shadow panjang: wick > 70% of range
      if((upperWick + lowerWick) > range * 0.7) return BASE_SHADOW;
      // Small body: body < 30% of range
      if(body < range * 0.3) return BASE_SMALL_BODY;
      // Hidden shadow: small wick but strong close
      if(upperWick < range * 0.1 && lowerWick < range * 0.1 && body > range * 0.6) return BASE_HIDDEN_SHADOW;
      // Momentum: body > 70% of range
      if(body > range * 0.7) return BASE_MOMENTUM;
      
      return BASE_UNKNOWN;
   }
   
   // Calculate momentum size (displacement)
   double CalcMomentumSize(int bar, bool isBullish) {
      double displacement = 0;
      for(int i = 1; i <= 3; i++) {
         double c0 = iClose(m_sym, m_tf, bar);
         double c1 = iClose(m_sym, m_tf, bar - i);
         if(isBullish && c1 > c0) displacement += (c1 - c0);
         if(!isBullish && c1 < c0) displacement += (c0 - c1);
      }
      return displacement;
   }
   
   // Score base quality
   double ScoreBaseQuality(ENUM_BASE_TYPE type) {
      switch(type) {
         case BASE_DOJI:        return 0.8;
         case BASE_PINBAR:    return 0.9;
         case BASE_SHADOW:    return 0.7;
         case BASE_SMALL_BODY: return 0.6;
         case BASE_HIDDEN_SHADOW: return 0.75;
         case BASE_MOMENTUM:  return 0.85;
         default: return 0.5;
      }
   }
   
   // Score momentum quality
   double ScoreMomentum(double momentumPts, double atr) {
      if(atr <= 0) return 0.5;
      double ratio = momentumPts / atr;
      if(ratio > 2.0) return 1.0;
      if(ratio > 1.5) return 0.8;
      if(ratio > 1.0) return 0.6;
      return 0.3;
   }

public:
   CCausalZoneDetector(string sym, ENUM_TIMEFRAMES tf, int maxZones, int lookback) {
      m_sym = sym;
      m_tf = tf;
      m_maxZones = maxZones;
      m_lookback = lookback;
   }
   
   // Detect all cause zones
   void DetectZones() {
      ArrayResize(m_zones, 0);
      double atr = iATR(m_sym, m_tf, 14, 1);
      
      for(int i = m_lookback; i >= 1; i--) {
         ENUM_BASE_TYPE baseType = DetectBaseType(i);
         if(baseType == BASE_UNKNOWN) continue;
         
         double o = iOpen(m_sym, m_tf, i);
         double c = iClose(m_sym, m_tf, i);
         double h = iHigh(m_sym, m_tf, i);
         double l = iLow(m_sym, m_tf, i);
         bool isBullish = (c > o);
         
         double momentum = CalcMomentumSize(i, isBullish);
         double baseScore = ScoreBaseQuality(baseType);
         double momScore = ScoreMomentum(momentum, atr);
         double zoneScore = (baseScore * 0.4 + momScore * 0.6);
         
         // Only create cause zone if score is good enough
         if(zoneScore < 0.5) continue;
         
         int idx = ArraySize(m_zones);
         ArrayResize(m_zones, idx + 1);
         
         m_zones[idx].zoneHigh = h;
         m_zones[idx].zoneLow = l;
         m_zones[idx].baseOpen = o;
         m_zones[idx].baseClose = c;
         m_zones[idx].momentumSize = momentum;
         m_zones[idx].energyLevel = 1.0; // Fresh
         m_zones[idx].consumptionCount = 0;
         m_zones[idx].baseType = baseType;
         m_zones[idx].createdTime = iTime(m_sym, m_tf, i);
         m_zones[idx].lastTested = 0;
         m_zones[idx].isBullish = isBullish;
         m_zones[idx].isActive = true;
         m_zones[idx].timeframe = EnumToString(m_tf);
         m_zones[idx].zoneScore = zoneScore;
      }
   }
   
   // Check if price is in any cause zone
   bool IsInCauseZone(double price, bool isLong, int& zoneIdx) {
      for(int i = 0; i < ArraySize(m_zones); i++) {
         if(!m_zones[i].isActive) continue;
         // Check if price within zone
         if(price >= m_zones[i].zoneLow && price <= m_zones[i].zoneHigh) {
            // Check if cause direction matches trade direction
            if((isLong && m_zones[i].isBullish) || (!isLong && !m_zones[i].isBullish)) {
               zoneIdx = i;
               return true;
            }
         }
      }
      return false;
   }
   
   // Get zone score for price
   double GetZoneScore(double price, bool isLong) {
      double bestScore = 0;
      for(int i = 0; i < ArraySize(m_zones); i++) {
         if(!m_zones[i].isActive) continue;
         if(price >= m_zones[i].zoneLow && price <= m_zones[i].zoneHigh) {
            if((isLong && m_zones[i].isBullish) || (!isLong && !m_zones[i].isBullish)) {
               bestScore = MathMax(bestScore, m_zones[i].zoneScore * m_zones[i].energyLevel);
            }
         }
      }
      return bestScore;
   }
   
   // Get nearest cause zone
   double GetNearestCauseDistance(double price, bool isLong) {
      double minDist = 999999;
      for(int i = 0; i < ArraySize(m_zones); i++) {
         if(!m_zones[i].isActive) continue;
         if((isLong && m_zones[i].isBullish) || (!isLong && !m_zones[i].isBullish)) {
            double dist = MathAbs(price - (m_zones[i].zoneHigh + m_zones[i].zoneLow) / 2);
            minDist = MathMin(minDist, dist);
         }
      }
      return minDist;
   }
   
   // Get total active zones
   int GetActiveZones() {
      int cnt = 0;
      for(int i = 0; i < ArraySize(m_zones); i++) {
         if(m_zones[i].isActive) cnt++;
      }
      return cnt;
   }
   
   // Get zone by index
   SCausalZone GetZone(int idx) {
      if(idx >= 0 && idx < ArraySize(m_zones)) return m_zones[idx];
      SCausalZone empty;
      empty.isActive = false;
      return empty;
   }
   
   // Access internal array
   SCausalZone& GetZones() { return m_zones; }
};

//+------------------------------------------------------------------+
//| CReturnBehaviorAnalyzer — Analyze Return Phase (Velocity/Pattern) |
//+------------------------------------------------------------------+
class CReturnBehaviorAnalyzer {
private:
   string    m_sym;
   ENUM_TIMEFRAMES m_tf;
   SReturnBehavior m_behavior;
   double    m_velocityThreshold; // pts per minute
   double    m_history[];
   datetime  m_historyTime[];
   
   // Calculate velocity of price approaching cause
   double CalcVelocity(double price, datetime now) {
      if(m_history[0] == 0) return 0;
      
      double minutes = (now - m_historyTime[0]) / 60.0;
      if(minutes <= 0) return 0;
      
      double distance = MathAbs(price - m_history[0]);
      return distance / minutes;
   }
   
   // Calculate path deviation (straightness)
   double CalcPathDeviation() {
      if(ArraySize(m_history) < 3) return 0;
      double total = 0;
      double straight = MathAbs(m_history[ArraySize(m_history)-1] - m_history[0]);
      for(int i = 1; i < ArraySize(m_history); i++) {
         total += MathAbs(m_history[i] - m_history[i-1]);
      }
      if(total == 0) return 0;
      return (total - straight) / total; // Higher = more zigzag
   }

public:
   CReturnBehaviorAnalyzer(string sym, ENUM_TIMEFRAMES tf, double velocityThreshold) {
      m_sym = sym;
      m_tf = tf;
      m_velocityThreshold = velocityThreshold;
      ArrayResize(m_history, 0);
      ArrayResize(m_historyTime, 0);
      m_behavior.isReturning = false;
      m_behavior.velocity = 0;
      m_behavior.distance = 999999;
      m_behavior.pathDeviation = 0;
   }
   
   // Start tracking return to cause
   void StartReturn(double price, datetime now) {
      m_behavior.startTime = now;
      m_behavior.startPrice = price;
      m_behavior.currentPrice = price;
      m_behavior.isReturning = true;
      m_behavior.ticksCount = 0;
      ArrayResize(m_history, 0);
      ArrayResize(m_historyTime, 0);
   }
   
   // Update return tracking
   void Update(double price, datetime now, double causeZoneCenter) {
      m_behavior.currentPrice = price;
      m_behavior.distance = MathAbs(price - causeZoneCenter);
      m_behavior.ticksCount++;
      
      // Add to history
      int idx = ArraySize(m_history);
      ArrayResize(m_history, idx + 1);
      ArrayResize(m_historyTime, idx + 1);
      m_history[idx] = price;
      m_historyTime[idx] = now;
      
      // Keep last 100 points
      if(ArraySize(m_history) > 100) {
         ArrayResize(m_history, 100);
         ArrayResize(m_historyTime, 100);
      }
      
      // Calculate velocity
      m_behavior.velocity = CalcVelocity(price, now);
      m_behavior.pathDeviation = CalcPathDeviation();
   }
   
   // Classify return behavior
   string ClassifyReturn() {
      if(!m_behavior.isReturning) return "none";
      
      // Fast return = high velocity = likely break
      if(m_behavior.velocity > m_velocityThreshold * 2.0) {
         if(m_behavior.pathDeviation < 0.3) return "fast_direct"; // Fast + direct = likely break
         return "fast_choppy"; // Fast but choppy = uncertain
      }
      // Slow return = low velocity = likely respect
      if(m_behavior.velocity < m_velocityThreshold * 0.5) {
         return "slow_gradual"; // Slow + gradual = likely respect
      }
      // Medium
      return "medium_mixed";
   }
   
   // Predict reaction based on return behavior
   double PredictReactionProb() {
      string classification = ClassifyReturn();
      if(classification == "fast_direct") return 0.3;  // 30% respect, 70% break
      if(classification == "fast_choppy") return 0.5;  // 50/50
      if(classification == "slow_gradual") return 0.8; // 80% respect
      if(classification == "medium_mixed") return 0.6; // 60% respect
      return 0.5;
   }
   
   // Get current behavior
   SReturnBehavior GetBehavior() { return m_behavior; }
   
   // Reset
   void Reset() {
      m_behavior.isReturning = false;
      ArrayResize(m_history, 0);
      ArrayResize(m_historyTime, 0);
   }
   
   // Is price returning to cause?
   bool IsReturning() { return m_behavior.isReturning; }
   
   double GetVelocity() { return m_behavior.velocity; }
   double GetDistance() { return m_behavior.distance; }
   double GetPathDeviation() { return m_behavior.pathDeviation; }
};

//+------------------------------------------------------------------+
//| CEnergyDecayModel — Track Zone Consumption & Energy Transfer      |
//+------------------------------------------------------------------+
class CEnergyDecayModel {
private:
   double    m_decayPerTest;    // Energy lost per test
   double    m_decayPerTime;    // Energy lost per bar
   double    m_maxDistance;     // Max distance before energy depleted
   
   // Calculate energy decay from consumption
   double CalcConsumptionDecay(int count) {
      return MathPow(1.0 - m_decayPerTest, count);
   }
   
   // Calculate energy decay from time
   double CalcTimeDecay(int barsElapsed) {
      return MathPow(1.0 - m_decayPerTime, barsElapsed);
   }
   
   // Calculate energy decay from distance
   double CalcDistanceDecay(double distance, double atr) {
      if(atr <= 0) return 1.0;
      double ratio = distance / atr;
      if(ratio > m_maxDistance) return 0;
      return 1.0 - (ratio / m_maxDistance);
   }

public:
   CEnergyDecayModel(double decayPerTest, double decayPerTime, double maxDistance) {
      m_decayPerTest = decayPerTest;
      m_decayPerTime = decayPerTime;
      m_maxDistance = maxDistance;
   }
   
   // Calculate current energy of a zone
   double CalcEnergy(SCausalZone& zone, double currentPrice, double atr, int currentBar) {
      if(!zone.isActive) return 0;
      
      double consumption = CalcConsumptionDecay(zone.consumptionCount);
      double time = 1.0;
      if(zone.createdTime > 0) {
         int barsElapsed = (int)((TimeCurrent() - zone.createdTime) / PeriodSeconds(PERIOD_H1));
         time = CalcTimeDecay(barsElapsed);
      }
      double distance = CalcDistanceDecay(
         MathAbs(currentPrice - (zone.zoneHigh + zone.zoneLow) / 2),
         atr
      );
      
      // Energy = base * consumption * time * distance
      double energy = zone.energyLevel * consumption * time * distance;
      return MathMax(0.1, MathMin(1.0, energy));
   }
   
   // Update zone energy after test
   void UpdateAfterTest(SCausalZone& zone, double currentPrice, double atr) {
      zone.consumptionCount++;
      zone.lastTested = TimeCurrent();
      zone.energyLevel = CalcEnergy(zone, currentPrice, atr, 0);
      
      // Deactivate if energy too low
      if(zone.energyLevel < 0.2) {
         zone.isActive = false;
      }
   }
   
   // Check if zone is fresh
   bool IsFresh(SCausalZone& zone) {
      return zone.isActive && zone.energyLevel > 0.7 && zone.consumptionCount < 2;
   }
   
   // Check if zone is consumed
   bool IsConsumed(SCausalZone& zone) {
      return !zone.isActive || zone.energyLevel < 0.3 || zone.consumptionCount >= 5;
   }
   
   // Energy transfer efficiency — higher when price moves efficiently
   double CalcTransferEfficiency(double startPrice, double currentPrice, double targetPrice, double atr) {
      double totalDistance = MathAbs(currentPrice - startPrice);
      double targetDistance = MathAbs(targetPrice - startPrice);
      if(targetDistance <= 0) return 0;
      
      // Efficiency = targetDistance / totalDistance (higher = more efficient)
      double efficiency = targetDistance / totalDistance;
      return MathMin(1.0, efficiency);
   }
};

//+------------------------------------------------------------------+
//| CTargetEfficiency — Calculate Clean Room & Target Compression       |
//+------------------------------------------------------------------+
class CTargetEfficiency {
private:
   string    m_sym;
   ENUM_TIMEFRAMES m_tf;
   int       m_lookback;
   
   // Count obstacles in path
   int CountObstacles(double startPrice, double targetPrice) {
      int obstacles = 0;
      double minP = MathMin(startPrice, targetPrice);
      double maxP = MathMax(startPrice, targetPrice);
      
      // Check recent highs/lows as obstacles
      for(int i = 1; i <= m_lookback; i++) {
         double h = iHigh(m_sym, m_tf, i);
         double l = iLow(m_sym, m_tf, i);
         if(h > minP && h < maxP && startPrice < targetPrice) obstacles++; // Going up, high is obstacle
         if(l > minP && l < maxP && startPrice > targetPrice) obstacles++; // Going down, low is obstacle
      }
      return obstacles;
   }

public:
   CTargetEfficiency(string sym, ENUM_TIMEFRAMES tf, int lookback) {
      m_sym = sym;
      m_tf = tf;
      m_lookback = lookback;
   }
   
   // Calculate target efficiency
   STargetEfficiency CalcEfficiency(double currentPrice, bool isLong, SCausalZone& causeZone) {
      STargetEfficiency eff;
      
      // Nearest target = previous high/low
      double nearestHigh = 0;
      double nearestLow = 999999;
      for(int i = 1; i <= m_lookback; i++) {
         nearestHigh = MathMax(nearestHigh, iHigh(m_sym, m_tf, i));
         nearestLow = MathMin(nearestLow, iLow(m_sym, m_tf, i));
      }
      
      eff.targetHigh = nearestHigh;
      eff.targetLow = nearestLow;
      eff.cleanRoomBuy = (nearestHigh - currentPrice) / Point;
      eff.cleanRoomSell = (currentPrice - nearestLow) / Point;
      
      // Compression ratio = (target range) / (recent range)
      double recentRange = nearestHigh - nearestLow;
      double olderRange = 0;
      double olderHigh = 0, olderLow = 999999;
      for(int i = m_lookback + 1; i <= m_lookback * 2; i++) {
         olderHigh = MathMax(olderHigh, iHigh(m_sym, m_tf, i));
         olderLow = MathMin(olderLow, iLow(m_sym, m_tf, i));
      }
      olderRange = olderHigh - olderLow;
      if(olderRange > 0) {
         eff.compressionRatio = recentRange / olderRange;
      } else {
         eff.compressionRatio = 1.0;
      }
      
      // Obstacles
      double target = isLong ? nearestHigh : nearestLow;
      eff.obstacleCount = CountObstacles(currentPrice, target);
      
      // Is efficient = clean room > 50 pts and obstacles < 2
      eff.isEfficient = (isLong ? eff.cleanRoomBuy : eff.cleanRoomSell) > 50 && eff.obstacleCount < 2;
      
      return eff;
   }
   
   // Get clean room percentage
   double GetCleanRoomPct(double currentPrice, bool isLong, double targetPrice) {
      double distance = MathAbs(targetPrice - currentPrice);
      double atr = iATR(m_sym, m_tf, 14, 1);
      if(atr <= 0) return 0;
      return MathMin(1.0, distance / (atr * 3.0));
   }
   
   // Check if target is narrowing
   bool IsTargetNarrowing() {
      double recentHigh = 0, recentLow = 999999;
      double olderHigh = 0, olderLow = 999999;
      
      for(int i = 1; i <= m_lookback; i++) {
         recentHigh = MathMax(recentHigh, iHigh(m_sym, m_tf, i));
         recentLow = MathMin(recentLow, iLow(m_sym, m_tf, i));
      }
      for(int i = m_lookback + 1; i <= m_lookback * 2; i++) {
         olderHigh = MathMax(olderHigh, iHigh(m_sym, m_tf, i));
         olderLow = MathMin(olderLow, iLow(m_sym, m_tf, i));
      }
      
      double recentRange = recentHigh - recentLow;
      double olderRange = olderHigh - olderLow;
      
      if(olderRange <= 0) return false;
      return (recentRange / olderRange) < 0.7; // 30% narrower = narrowing
   }
};

//+------------------------------------------------------------------+
//| CMultiTimeframeConfluence — Stack Causes Across Timeframes         |
//+------------------------------------------------------------------+
class CMultiTimeframeConfluence {
private:
   CCausalZoneDetector* m_htfDetector;
   CCausalZoneDetector* m_mtfDetector;
   CCausalZoneDetector* m_ltfDetector;
   
public:
   CMultiTimeframeConfluence(string sym) {
      m_htfDetector = new CCausalZoneDetector(sym, PERIOD_H4, 10, 20);
      m_mtfDetector = new CCausalZoneDetector(sym, PERIOD_H1, 15, 30);
      m_ltfDetector = new CCausalZoneDetector(sym, PERIOD_M15, 20, 50);
   }
   
   ~CMultiTimeframeConfluence() {
      if(m_htfDetector != NULL) { delete m_htfDetector; m_htfDetector = NULL; }
      if(m_mtfDetector != NULL) { delete m_mtfDetector; m_mtfDetector = NULL; }
      if(m_ltfDetector != NULL) { delete m_ltfDetector; m_ltfDetector = NULL; }
   }
   
   // Detect zones on all timeframes
   void DetectAll() {
      m_htfDetector.DetectZones();
      m_mtfDetector.DetectZones();
      m_ltfDetector.DetectZones();
   }
   
   // Calculate confluence score
   // Returns 0-1 score based on how many TFs align
   double CalcConfluenceScore(double price, bool isLong) {
      double htfScore = m_htfDetector.GetZoneScore(price, isLong);
      double mtfScore = m_mtfDetector.GetZoneScore(price, isLong);
      double ltfScore = m_ltfDetector.GetZoneScore(price, isLong);
      
      // Weighted: HTF 50%, MTF 30%, LTF 20%
      double score = htfScore * 0.5 + mtfScore * 0.3 + ltfScore * 0.2;
      
      // Bonus for alignment (all 3 present)
      if(htfScore > 0.5 && mtfScore > 0.5 && ltfScore > 0.5) {
         score += 0.1;
      }
      
      return MathMin(1.0, score);
   }
   
   // Check if HTF cause aligns with MTF cause
   bool IsAligned(double price, bool isLong) {
      int htfIdx, mtfIdx, ltfIdx;
      bool htfIn = m_htfDetector.IsInCauseZone(price, isLong, htfIdx);
      bool mtfIn = m_mtfDetector.IsInCauseZone(price, isLong, mtfIdx);
      bool ltfIn = m_ltfDetector.IsInCauseZone(price, isLong, ltfIdx);
      
      // At least 2 of 3 must align
      int count = 0;
      if(htfIn) count++;
      if(mtfIn) count++;
      if(ltfIn) count++;
      
      return count >= 2;
   }
   
   // Get best zone from any TF
   SCausalZone GetBestZone(double price, bool isLong) {
      SCausalZone best;
      best.zoneScore = 0;
      
      int htfIdx, mtfIdx, ltfIdx;
      if(m_htfDetector.IsInCauseZone(price, isLong, htfIdx)) {
         SCausalZone z = m_htfDetector.GetZone(htfIdx);
         if(z.zoneScore > best.zoneScore) best = z;
      }
      if(m_mtfDetector.IsInCauseZone(price, isLong, mtfIdx)) {
         SCausalZone z = m_mtfDetector.GetZone(mtfIdx);
         if(z.zoneScore > best.zoneScore) best = z;
      }
      if(m_ltfDetector.IsInCauseZone(price, isLong, ltfIdx)) {
         SCausalZone z = m_ltfDetector.GetZone(ltfIdx);
         if(z.zoneScore > best.zoneScore) best = z;
      }
      
      return best;
   }
   
   // Get zone counts
   int GetHTFCount() { return m_htfDetector.GetActiveZones(); }
   int GetMTFCount() { return m_mtfDetector.GetActiveZones(); }
   int GetLTFCount() { return m_ltfDetector.GetActiveZones(); }
};

//+------------------------------------------------------------------+
//| Causal-Effect Global Instances                                    |
//+------------------------------------------------------------------+
CCausalZoneDetector* g_causalDetector;
CReturnBehaviorAnalyzer* g_returnAnalyzer;
CEnergyDecayModel* g_energyModel;
CTargetEfficiency* g_targetEff;
CMultiTimeframeConfluence* g_confluence;

//+------------------------------------------------------------------+
//| GLOBAL INSTANCES (Existing)                                       |
//+------------------------------------------------------------------+
CSMSEngine*  g_sms;
CDeltaEngine* g_delta;
CTradeManager* g_trade;
CNexusAPI*   g_api;

//+------------------------------------------------------------------+
//| CAUSAL-EFFECT SIGNAL GENERATOR                                     |
//| Returns true if signal generated, false if no signal              |
//| Incorporates: cause zones, return behavior, energy, confluence    |
//+------------------------------------------------------------------+
bool GenerateCausalSignal(STradeSignal& sig, bool useCausal) {
   if(!useCausal) return false;
   
   // Reset signal
   sig.tradeType   = WRONG_VALUE;
   sig.confidence  = 0.0;
   sig.rationale   = "";
   sig.smsType     = "none";
   sig.regime      = g_currentRegime;
   
   // Detect zones on all TFs
   g_confluence.DetectAll();
   
   double price = Close(1);
   double atr = iATR(Symbol(), PERIOD_H1, 14, 1);
   
   // Check for confluence (at least 2 TFs aligned)
   bool bullAligned = g_confluence.IsAligned(price, true);
   bool bearAligned = g_confluence.IsAligned(price, false);
   
   if(!bullAligned && !bearAligned) return false;
   
   // Determine trade direction
   bool isLong = bullAligned;
   if(bullAligned && bearAligned) {
      // Both aligned — use confluence score
      double bullScore = g_confluence.CalcConfluenceScore(price, true);
      double bearScore = g_confluence.CalcConfluenceScore(price, false);
      isLong = bullScore > bearScore;
   }
   
   // Get best zone
   SCausalZone cause = g_confluence.GetBestZone(price, isLong);
   if(!cause.isActive) return false;
   
   // Check energy
   double energy = g_energyModel.CalcEnergy(cause, price, atr, 0);
   if(g_energyModel.IsConsumed(cause)) {
      sig.rationale = "CAUSE_CONSUMED|SKIP";
      return false;
   }
   
   // Check if price is returning to cause
   double causeCenter = (cause.zoneHigh + cause.zoneLow) / 2;
   g_returnAnalyzer.StartReturn(price, TimeCurrent());
   g_returnAnalyzer.Update(price, TimeCurrent(), causeCenter);
   
   // Classify return behavior
   string returnType = g_returnAnalyzer.ClassifyReturn();
   double respectProb = g_returnAnalyzer.PredictReactionProb();
   
   // Fast return = likely break, skip
   if(returnType == "fast_direct" && respectProb < 0.4) {
      sig.rationale = "FAST_RETURN|LIKELY_BREAK|SKIP";
      return false;
   }
   
   // Calculate target efficiency
   STargetEfficiency eff = g_targetEff.CalcEfficiency(price, isLong, cause);
   
   // Check clean room
   if(!eff.isEfficient) {
      sig.rationale = "NO_CLEAN_ROOM|SKIP";
      return false;
   }
   
   // Check target narrowing
   if(g_targetEff.IsTargetNarrowing()) {
      // Reduce TP if target is narrowing
      eff.targetHigh = (eff.targetHigh + causeCenter) / 2;
      eff.targetLow = (eff.targetLow + causeCenter) / 2;
   }
   
   // Calculate SL and TP
   double slPoints = atr * 1.5 / Point;
   double tpPoints = isLong ? (eff.targetHigh - price) / Point : (price - eff.targetLow) / Point;
   
   // Adjust SL based on cause zone
   if(isLong) {
      sig.sl = MathMax(slPoints, (price - cause.zoneLow) / Point + 10);
   } else {
      sig.sl = MathMax(slPoints, (cause.zoneHigh - price) / Point + 10);
   }
   
   sig.tp = tpPoints;
   
   // Calculate confidence
   double confluenceScore = g_confluence.CalcConfluenceScore(price, isLong);
   double energyScore = energy;
   double returnScore = respectProb;
   double cleanRoomScore = eff.isEfficient ? 0.8 : 0.4;
   
   sig.confidence = MathMin(0.95, 
      confluenceScore * 0.35 + 
      energyScore * 0.25 + 
      returnScore * 0.25 + 
      cleanRoomScore * 0.15
   );
   
   sig.tradeType = isLong ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
   sig.rationale = StringFormat("CAUSE|%s|ENERGY%.0f%%|RETURN_%s|CONFL%.0f%%|CLEAN%.0f%%",
      cause.isBullish ? "BULL" : "BEAR",
      energy * 100,
      returnType,
      confluenceScore * 100,
      cleanRoomScore * 100
   );
   sig.smsType = "causal_zone";
   sig.riskReward = sig.tp / sig.sl;
   
   return true;
}


//+------------------------------------------------------------------+
//| ONINIT                                                            |
//+------------------------------------------------------------------+
int OnInit() {
   // Existing instances
   g_sms   = new CSMSEngine(Symbol());
   g_delta = new CDeltaEngine(Symbol());
   g_trade = new CTradeManager(InpMagic, Symbol());
   g_api   = new CNexusAPI(InpAPIHost, InpAPIKey, InpAPITimeout);
   
   // Causal-Effect instances
   g_causalDetector = new CCausalZoneDetector(Symbol(), PERIOD_H1, 15, 30);
   g_returnAnalyzer = new CReturnBehaviorAnalyzer(Symbol(), PERIOD_M15, 5.0);
   g_energyModel    = new CEnergyDecayModel(0.15, 0.02, 5.0); // 15% per test, 2% per bar, 5x ATR max
   g_targetEff      = new CTargetEfficiency(Symbol(), PERIOD_H1, 20);
   g_confluence     = new CMultiTimeframeConfluence(Symbol());
   
   g_barTimes[0] = iTime(Symbol(), InpHTF, 0);
   g_barTimes[1] = iTime(Symbol(), InpMTF, 0);
   g_barTimes[2] = iTime(Symbol(), InpLTF, 0);
   g_barTimes[3] = iTime(Symbol(), PERIOD_M5, 0);
   g_dayStart    = TimeCurrent();
   g_equityPeak  = AccountEquity();
   
   Print("=== nexus-core Initialized ===");
   Print("  Symbol  : ", Symbol());
   Print("  HTF     : ", EnumToString(InpHTF));
   Print("  MTF     : ", EnumToString(InpMTF));
   Print("  LTF     : ", EnumToString(InpLTF));
   Print("  SMS     : ", InpUseSMS ? "ON" : "OFF");
   Print("  Delta   : ", InpUseDelta ? "ON" : "OFF");
   Print("  Causal  : ON (Cause-Effect Engine v1)");
   Print("  API     : ", InpUseAPI ? "ON (connected to " + InpAPIHost + ")" : "OFF (manual regime)");
   Print("  Risk    : ", InpRiskPercent, "% per trade | ", InpMaxTradesPerDay, " trades/day max");
   
   return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
//| ONDEINIT                                                          |
//+------------------------------------------------------------------+
void OnDeinit(const int reason) {
   if(g_sms   != NULL) { delete g_sms;   g_sms   = NULL; }
   if(g_delta != NULL) { delete g_delta; g_delta = NULL; }
   if(g_trade != NULL) { delete g_trade; g_trade = NULL; }
   if(g_api   != NULL) { delete g_api;   g_api   = NULL; }
   // Causal-Effect cleanup
   if(g_causalDetector != NULL) { delete g_causalDetector; g_causalDetector = NULL; }
   if(g_returnAnalyzer != NULL) { delete g_returnAnalyzer; g_returnAnalyzer = NULL; }
   if(g_energyModel    != NULL) { delete g_energyModel;    g_energyModel    = NULL; }
   if(g_targetEff      != NULL) { delete g_targetEff;      g_targetEff      = NULL; }
   if(g_confluence     != NULL) { delete g_confluence;     g_confluence     = NULL; }
   Print("=== nexus-core Deinitialized ===");
}

//+------------------------------------------------------------------+
//| ONTICK                                                            |
//+------------------------------------------------------------------+
void OnTick() {
   // Bar change check
   datetime nowBars[4];
   nowBars[0] = iTime(Symbol(), InpHTF, 0);
   nowBars[1] = iTime(Symbol(), InpMTF, 0);
   nowBars[2] = iTime(Symbol(), InpLTF, 0);
   nowBars[3] = iTime(Symbol(), PERIOD_M5, 0);
   
   bool newBar = false;
   for(int i = 0; i < 4; i++) {
      if(nowBars[i] != g_barTimes[i]) {
         newBar = true;
         g_barTimes[i] = nowBars[i];
      }
   }
   
   if(!newBar) return; // Only run on new bar
   
   // Daily reset
   if(TimeDay(TimeCurrent()) != TimeDay(g_dayStart)) {
      g_tradesToday = 0;
      g_riskToday   = 0.0;
      g_dayStart    = TimeCurrent();
   }
   
   // Equity peak
   double equity = AccountEquity();
   if(equity > g_equityPeak) g_equityPeak = equity;
   
   // Drawdown check
   double dd = (g_equityPeak - equity) / g_equityPeak * 100.0;
   if(dd >= InpMaxDDPercent) {
      Alert("[nexus] MAX DRAWDOWN ", DoubleToString(dd, 1), "% - TRADING PAUSED");
      CloseAllOrders();
      return;
   }
   
   // Session filter
   if(InpUseSessionFilter) {
      int serverHour = Hour();
      if(serverHour < InpTradeHourStart || serverHour > InpTradeHourEnd) return;
   }
   
   // Spread check
   if(Ask - Bid > InpMaxSpread * Point) return;
   
   // Get regime (API or manual)
   double regimeConf;
   g_currentRegime = g_api.GetRegime(Symbol(), regimeConf);
   g_regimeConf   = regimeConf;
   
   // Refresh SMS
   if(InpUseSMS && newBar) {
      g_sms.DetectOrderBlocks();
      g_sms.DetectFVGs();
      g_sms.DetectLiquiditySweeps();
   }
   
   // Trailing stop
   if(InpTrailingStart > 0) {
      g_trade.TrailStop(InpTrailingStart, InpTrailingStep);
   }
   
   // Check trade limits
   if(g_tradesToday >= InpMaxTradesPerDay) return;
   if(g_trade.CountOpenOrders() >= InpMaxOpenTrades) return;
   
   // Generate signals
   STradeSignal sig;
   if(GenerateSignal(sig)) {
      if(g_trade.OpenOrder(sig, sig.rationale)) {
         g_tradesToday++;
         g_api.LogTrade(OrderTicket(), "OPEN", sig.rationale);
      }
   }
}

//+------------------------------------------------------------------+
//| GENERATESIGNAL - Out-of-the-box signal generation                 |
//+------------------------------------------------------------------+
bool GenerateSignal(STradeSignal& sig) {
   // Reset
   sig.tradeType   = WRONG_VALUE;
   sig.confidence  = 0.0;
   sig.rationale   = "";
   sig.smsType     = "none";
   sig.regime      = g_currentRegime;
   
   // === CAUSAL-EFFECT SIGNAL FIRST ===
   bool causal = GenerateCausalSignal(sig, true);
   if(causal) {
      // Log causal zone consumption
      double price = Close(1);
      double atr = iATR(Symbol(), PERIOD_H1, 14, 1);
      SCausalZone cause = g_confluence.GetBestZone(price, sig.tradeType == ORDER_TYPE_BUY);
      if(cause.isActive) {
         g_energyModel.UpdateAfterTest(cause, price, atr);
      }
      return true;
   }
   
   // === FALLBACK: REGIME-ADAPTIVE SIGNAL ===
   
   // Check delta absorption
   bool absorption = InpUseDelta && g_delta.IsAbsorption();
   
   // Get HTF trend (H4)
   double emaFastHTF = iMA(Symbol(), InpHTF, 20, 0, MODE_EMA, PRICE_CLOSE, 1);
   double emaSlowHTF = iMA(Symbol(), InpHTF, 50, 0, MODE_EMA, PRICE_CLOSE, 1);
   bool   htfBullish = emaFastHTF > emaSlowHTF;
   bool   htfBearish = emaFastHTF < emaSlowHTF;
   
   // Get MTF zone (H1)
   double emaFastMTF = iMA(Symbol(), InpMTF, 20, 0, MODE_EMA, PRICE_CLOSE, 1);
   double emaSlowMTF = iMA(Symbol(), InpMTF, 50, 0, MODE_EMA, PRICE_CLOSE, 1);
   double price      = Close(1);
   double atr        = iATR(Symbol(), PERIOD_H1, 14, 1);
   double rsi       = iRSI(Symbol(), PERIOD_H1, 14, PRICE_CLOSE, 1);
   
   // Get LTF confirmation (M15)
   double emaFastLTF = iMA(Symbol(), InpLTF, 8, 0, MODE_EMA, PRICE_CLOSE, 1);
   double emaSlowLTF = iMA(Symbol(), InpLTF, 21, 0, MODE_EMA, PRICE_CLOSE, 1);
   double ltfBullish = emaFastLTF > emaSlowLTF;
   double ltfBearish = emaFastLTF < emaSlowLTF;
   
   double slPoints = atr * 1.5 / Point;
   double tpPoints = atr * 3.0 / Point;
   
   // SMS Scoring
   double smsBullScore = 0;
   double smsBearScore = 0;
   
   if(InpUseSMS) {
      smsBullScore += g_sms.GetOBZoneScore(price, true);
      smsBearScore += g_sms.GetOBZoneScore(price, false);
      smsBullScore += g_sms.GetFVGZoneScore(price) * 0.5;
      smsBearScore += g_sms.GetFVGZoneScore(price) * 0.5;
   }
   
   string liqCtx = InpUseSMS ? g_sms.GetLiquidityContext() : "none";
   
   // ====== REGIME-ADAPTIVE SIGNAL GENERATION ======
   // This is where we differ from martingale EAs
   // Strategy changes based on detected regime
   
   switch(g_currentRegime) {
      case REGIME_TRENDING_STRONG: {
         // In strong trend: wait for pullback to EMA, confirm with SMS
         // Entry only if: pullback to EMA + SMS zone + absorption
         double emaDeviation = MathAbs(price - emaSlowMTF) / emaSlowMTF;
         
         if(htfBullish && ltfBullish && emaDeviation < 0.002) {
            if(smsBullScore > 0.3 || liqCtx == "sweep_low") {
               sig.tradeType  = ORDER_TYPE_BUY;
               sig.sl         = slPoints * 1.0;
               sig.tp         = tpPoints * 1.5;
               sig.confidence = MathMin(0.5 + smsBullScore + regimeConf * 0.3, 0.95);
               sig.rationale  = "STRONG_TREND|PULLBACK|OB_ZONE";
               sig.smsType    = "trend_pullback";
               sig.riskReward = (tpPoints * 1.5) / (slPoints * 1.0);
               return true;
            }
         }
         
         if(htfBearish && ltfBearish && emaDeviation < 0.002) {
            if(smsBearScore > 0.3 || liqCtx == "sweep_high") {
               sig.tradeType  = ORDER_TYPE_SELL;
               sig.sl         = slPoints * 1.0;
               sig.tp         = tpPoints * 1.5;
               sig.confidence = MathMin(0.5 + smsBearScore + regimeConf * 0.3, 0.95);
               sig.rationale  = "STRONG_TREND|PULLBACK|OB_ZONE";
               sig.smsType    = "trend_pullback";
               sig.riskReward = (tpPoints * 1.5) / (slPoints * 1.0);
               return true;
            }
         }
         break;
      }
      
      case REGIME_RANGING: {
         // In range: trade SR bounces
         double rangeHigh = iHighest(Symbol(), InpMTF, MODE_HIGH, 20, 1);
         double rangeLow  = iLowest(Symbol(), InpMTF, MODE_LOW, 20, 1);
         double rangeMid  = (rangeHigh + rangeLow) / 2;
         
         if(price <= rangeLow * 1.001) {
            if(smsBullScore > 0.2 || absorption) {
               sig.tradeType  = ORDER_TYPE_BUY;
               sig.sl         = slPoints * 0.8;
               sig.tp         = MathMax(tpPoints, (rangeMid - price) / Point);
               sig.confidence = MathMin(0.4 + smsBullScore + 0.2, 0.8);
               sig.rationale  = "RANGE|BOUNCE_LOW|SR";
               sig.smsType    = "range_sr_bounce";
               sig.riskReward = sig.tp / sig.sl;
               return true;
            }
         }
         
         if(price >= rangeHigh * 0.999) {
            if(smsBearScore > 0.2 || absorption) {
               sig.tradeType  = ORDER_TYPE_SELL;
               sig.sl         = slPoints * 0.8;
               sig.tp         = MathMax(tpPoints, (price - rangeMid) / Point);
               sig.confidence = MathMin(0.4 + smsBearScore + 0.2, 0.8);
               sig.rationale  = "RANGE|BOUNCE_HIGH|SR";
               sig.smsType    = "range_sr_bounce";
               sig.riskReward = sig.tp / sig.sl;
               return true;
            }
         }
         break;
      }
      
      case REGIME_VOLATILE: {
         // Volatile market: reduce exposure, wider SL
         if(g_regimeConf < 0.5) return false; // Not confident = skip
         
         double atrMult = atr * 2.5 / Point;
         double tpMult  = atr * 5.0 / Point;
         
         if(absorption) {
            sig.sl         = atrMult;
            sig.tp         = tpMult;
            sig.confidence = g_regimeConf * 0.5;
            sig.riskReward = tpMult / atrMult;
            
            if(htfBullish) { sig.tradeType = ORDER_TYPE_BUY; sig.rationale = "VOLATILE|ABSORPTION_LONG"; sig.smsType = "liq_sweep_reversal"; }
            else           { sig.tradeType = ORDER_TYPE_SELL; sig.rationale = "VOLATILE|ABSORPTION_SHORT"; sig.smsType = "liq_sweep_reversal"; }
            
            return true;
         }
         break;
      }
      
      case REGIME_BREAKOUT: {
         // Breakout mode: wait for retest of structure
         // Don't chase breakout, wait pullback
         if(price < emaSlowMTF && htfBullish) {
            sig.tradeType  = ORDER_TYPE_BUY;
            sig.sl         = slPoints;
            sig.tp         = tpPoints;
            sig.confidence = 0.5;
            sig.rationale  = "BREAKOUT|RETEST_LONG";
            sig.smsType    = "breakout_retest";
            sig.riskReward = tpPoints / slPoints;
            return true;
         }
         
         if(price > emaSlowMTF && htfBearish) {
            sig.tradeType  = ORDER_TYPE_SELL;
            sig.sl         = slPoints;
            sig.tp         = tpPoints;
            sig.confidence = 0.5;
            sig.rationale  = "BREAKOUT|RETEST_SHORT";
            sig.smsType    = "breakout_retest";
            sig.riskReward = tpPoints / slPoints;
            return true;
         }
         break;
      }
      
      default: {
         // Unknown regime: ultra-conservative
         if(regimeConf > 0.7 && absorption) {
            sig.sl         = slPoints * 1.2;
            sig.tp         = tpPoints * 0.8;
            sig.confidence = regimeConf * 0.3;
            sig.riskReward = 0.67;
            
            if(htfBullish) { sig.tradeType = ORDER_TYPE_BUY; sig.rationale = "UNKNOWN|ALPHA_ABSORPTION"; sig.smsType = "unknown_regime"; }
            else           { sig.tradeType = ORDER_TYPE_SELL; sig.rationale = "UNKNOWN|ALPHA_ABSORPTION"; sig.smsType = "unknown_regime"; }
            
            return true;
         }
         break;
      }
   }
   
   return false;
}

//+------------------------------------------------------------------+
//| CLOSEALLORDERS                                                    |
//+------------------------------------------------------------------+
void CloseAllOrders() {
   for(int i = OrdersTotal() - 1; i >= 0; i--) {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if(OrderSymbol() != Symbol()) continue;
      if(OrderMagicNumber() != InpMagic) continue;
      if(OrderType() > OP_SELL) continue;
      if(!OrderClose(OrderTicket(), OrderLots(), Bid, InpSlippage, 
                     (OrderType() == ORDER_TYPE_BUY) ? clrRed : clrBlue))
         Print("[Close Error] Err:", GetLastError());
   }
}

//+------------------------------------------------------------------+
//| ONCHARTEVENT                                                      |
//+------------------------------------------------------------------+
void OnChartEvent(const int id, const long& lparam, const double& dparam, const string& sparam) {
   string regimeStr = "UNKNOWN";
   switch(g_currentRegime) {
      case REGIME_TRENDING_STRONG: regimeStr = "TRENDING_STRONG"; break;
      case REGIME_TRENDING_WEAK:   regimeStr = "TRENDING_WEAK";   break;
      case REGIME_RANGING:         regimeStr = "RANGING";         break;
      case REGIME_VOLATILE:        regimeStr = "VOLATILE";        break;
      case REGIME_LOW_VOLUME:      regimeStr = "LOW_VOLUME";      break;
      case REGIME_BREAKOUT:        regimeStr = "BREAKOUT";        break;
      case REGIME_UNKNOWN:         regimeStr = "UNKNOWN";         break;
   }
   
   Comment(StringFormat(
      "=== nexus-core | VicChelenge System v1.1 ===\n"
      "Regime  : %s (%.0f%% confidence)\n"
      "Balance : %.2f  Equity: %.2f\n"
      "Open    : %d/%d  TradesToday: %d/%d\n"
      "SMS     : OB:%d | FVG:%d | LIQ:%d\n"
      "Causal  : Z:%d | Vel:%.1f | NRG:%.0f%%\n"
      "Return  : %s | Confl:%d/%d/%d\n"
      "Delta   : %s\n"
      "API     : %s\n"
      "\n"
      "NO MARTINGALE. NO GRID.\n"
      "PURE INSTITUTIONAL FLOW.",
      regimeStr, g_regimeConf * 100,
      AccountBalance(), AccountEquity(),
      g_trade.CountOpenOrders(), InpMaxOpenTrades,
      g_tradesToday, InpMaxTradesPerDay,
      InpUseSMS ? g_sms.GetOBTotal() : 0,
      InpUseSMS ? g_sms.GetFVGTotal() : 0,
      InpUseSMS ? g_sms.GetLiqTotal() : 0,
      g_causalDetector != NULL ? g_causalDetector.GetActiveZones() : 0,
      g_returnAnalyzer != NULL ? g_returnAnalyzer.GetVelocity() : 0,
      g_energyModel != NULL ? (g_causalDetector != NULL ? g_energyModel.CalcEnergy(
         g_causalDetector.GetZone(0), Close(1), iATR(Symbol(), PERIOD_H1, 14, 1), 0
      ) * 100 : 0) : 0,
      g_returnAnalyzer != NULL ? g_returnAnalyzer.ClassifyReturn() : "OFF",
      g_confluence != NULL ? g_confluence.GetHTFCount() : 0,
      g_confluence != NULL ? g_confluence.GetMTFCount() : 0,
      g_confluence != NULL ? g_confluence.GetLTFCount() : 0,
      InpUseDelta ? (g_delta.IsAbsorption() ? "ABSORBING" : "NORMAL") : "OFF",
      InpUseAPI ? "CONNECTED" : "OFFLINE"
   ));
}
