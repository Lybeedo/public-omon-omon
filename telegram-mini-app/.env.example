# 🚀 Telegram Mini App — Config
# Copy this file to .env and fill in
# ===================================

# Bot token dari @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# URL hosting (HTTPS wajib!)
WEBAPP_URL=https://YOUR-DOMAIN.com

# Port server (default: 3000)
PORT=3000
