FROM python:3.11-slim

WORKDIR /app

COPY nexus-llm/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY nexus-llm/nexus_llm.py .

EXPOSE 8002

HEALTHCHECK --interval=30s --timeout=10s --retries=3 CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8002/health')"

CMD ["python", "nexus_llm.py"]